DATABASE_URL="postgresql://masterusername:password(db-endpoint) "
JWT_SECRET_KEY="Secret"

AWS_REGION=us-east-1
AWS_ACCESS_KEY=acess-key-here
AWS_SECRET_KEY=acess-secret-key

# AWS ElastiCache Redis — cluster must be in the same VPC as EC2 and reachable on port 6379.
# Consumed by RedisService for agent WebSocket scan routing (pub/sub).
REDIS_URL="redis://<your-elasticache-cluster>.xxxxxx.ng.0001.use1.cache.amazonaws.com:6379"
