generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt
  isActive          Boolean                 @default(true)
  email             String                  @unique
  password          String
  userName          String
  profileImage      String?
  id                String                  @id @default(uuid()) @db.Uuid
  client            Client?
  employee          Employee[]
  guard             Guard[]
  organizations     Organization?           @relation("UserOrganization")
  userOffice        UserOffice[]
  userRoles         UserRole[]              @relation("UserUserRoles")
  /// @deprecated Legacy userId-keyed agent config; use OfficeAgent for org/office-keyed bridge.
  fingerprintAgent  FingerprintAgentConfig?
  /// @deprecated Legacy userId-keyed agent registration; use OfficeAgent for org/office-keyed bridge.
  agentRegistration AgentRegistration?
  fingerprintScans  FingerprintScan[]

  // Inventory Relations
  purchaseRequests         PurchaseRequest[]  @relation("PurchaseRequestRequester")
  purchaseRequestsApproved PurchaseRequest[]  @relation("PurchaseRequestApprover")
  purchaseOrders           PurchaseOrder[]
  grnsReceivedBy           Grn[]              @relation("GrnReceivedBy")
  grnsInspectedBy          Grn[]              @relation("GrnInspectedBy")
  stockTransfersInitiated  StockTransfer[]    @relation("StockTransferInitiator")
  stockTransfersReceived   StockTransfer[]    @relation("StockTransferReceiver")
  issuances                IssuanceRegister[]
  returns                  ReturnRegister[]
  stockMovements           StockMovement[]
}

model Role {
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  isActive  Boolean    @default(true)
  roleName  String
  id        String     @id @default(uuid()) @db.Uuid
  userRoles UserRole[] @relation("RoleUserRoles")
}

model UserRole {
  id     String @id @default(uuid()) @db.Uuid
  userId String @db.Uuid
  roleId String @db.Uuid
  role   Role   @relation("RoleUserRoles", fields: [roleId], references: [id], onDelete: Cascade)
  user   User   @relation("UserUserRoles", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
}

model Feature {
  id                   String                @id @default(uuid()) @db.Uuid
  name                 String                @unique
  description          String?
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  organizationFeatures OrganizationFeature[]
}

model OrganizationFeature {
  id             String       @id @default(uuid()) @db.Uuid
  organizationId String       @db.Uuid
  featureId      String       @db.Uuid
  feature        Feature      @relation(fields: [featureId], references: [id], onDelete: Cascade)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, featureId])
}

model Organization {
  id                   String                    @id @default(uuid()) @db.Uuid
  createdAt            DateTime                  @default(now())
  updatedAt            DateTime                  @updatedAt
  isActive             Boolean                   @default(true)
  organizationName     String
  userId               String                    @unique @db.Uuid
  organizationLogo     String?
  addressLine1         String
  addressLine2         String?
  city                 String
  phoneNumber1         String
  phoneNumber2         String?
  province             String
  subFeaturesData      Json?                     @default("{}")
  client               Client[]
  employee             Employee[]
  guard                Guard[]
  guardCategories      GuardCategory[]
  office               Office[]
  user                 User                      @relation("UserOrganization", fields: [userId], references: [id], onDelete: Cascade)
  bankAccount          OrganizationBankAccount[]
  organizationFeatures OrganizationFeature[]
  userOffice           UserOffice[]

  // Inventory Relations
  stores           Store[]            @relation("OrganizationStores")
  itemCategories   ItemCategory[]     @relation("OrganizationItemCategories")
  itemGroups       ItemGroup[]        @relation("OrganizationItemGroups")
  vendors          Vendor[]           @relation("OrganizationVendors")
  items            Item[]             @relation("OrganizationItems")
  inventory        Inventory[]        @relation("OrganizationInventory")
  purchaseRequests PurchaseRequest[]  @relation("OrganizationPurchaseRequests")
  purchaseOrders   PurchaseOrder[]    @relation("OrganizationPurchaseOrders")
  grns             Grn[]              @relation("OrganizationGrns")
  stockTransfers   StockTransfer[]    @relation("OrganizationStockTransfers")
  inventoryCards   InventoryCard[]    @relation("OrganizationInventoryCards")
  issuances        IssuanceRegister[] @relation("OrganizationIssuances")
  returns          ReturnRegister[]   @relation("OrganizationReturns")
  stockMovements   StockMovement[]    @relation("OrganizationStockMovements")
  officeAgents     OfficeAgent[]
  fingerprintScans FingerprintScan[]
}

model Office {
  id               String       @id @default(uuid()) @db.Uuid
  organizationId   String       @db.Uuid
  province         String
  contactNumber    String
  email            String
  address          String
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  isActive         Boolean      @default(true)
  addressOpt       String?
  city             String       @default("N/A")
  branchName       String       @default("N/A")
  contactNumberOpt String?
  branchCode       Int          @default(autoincrement())
  guard            Guard[]
  organization     Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userOffice       UserOffice[]
  location         Location[]

  // Inventory Relations
  stores           Store[]           @relation("OfficeStores")
  purchaseRequests PurchaseRequest[]
  purchaseOrders   PurchaseOrder[]
  officeAgent      OfficeAgent?
  fingerprintScans FingerprintScan[]
}

/// @deprecated Legacy userId-keyed agent config; use OfficeAgent for org/office-keyed bridge.
model FingerprintAgentConfig {
  id              String   @id @default(uuid()) @db.Uuid
  userId          String   @unique @db.Uuid
  agentIp         String // e.g., "192.168.1.50"
  agentPort       Int      @default(8765)
  configuredAt    DateTime @default(now())
  updatedAt       DateTime @updatedAt
  updatedByUserId String?  @db.Uuid
  isActive        Boolean  @default(true)
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

/// @deprecated Legacy userId-keyed agent registration; use OfficeAgent for org/office-keyed bridge.
model AgentRegistration {
  id            String      @id @default(uuid()) @db.Uuid
  userId        String      @unique @db.Uuid
  agentIp       String // e.g., "192.168.100.50"
  agentPort     Int         @default(9001)
  status        AgentStatus @default(OFFLINE)
  lastHeartbeat DateTime?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
}

model OfficeAgent {
  id              String       @id @default(uuid()) @db.Uuid
  organizationId  String       @db.Uuid
  officeId        String       @unique @db.Uuid
  agentSecretHash String
  status          AgentStatus  @default(OFFLINE)
  lastSeenAt      DateTime?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  office          Office       @relation(fields: [officeId], references: [id], onDelete: Cascade)

  @@unique([organizationId, officeId])
  @@index([status])
}

model FingerprintScan {
  id             String       @id @default(uuid()) @db.Uuid
  organizationId String       @db.Uuid
  officeId       String       @db.Uuid
  userId         String       @db.Uuid
  s3Key          String
  s3Url          String?
  fingerName     String?
  quality        Int?
  status         ScanStatus   @default(PENDING)
  errorCode      String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  office         Office       @relation(fields: [officeId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([organizationId, officeId])
  @@index([userId])
}

model OrganizationBankAccount {
  id             String       @id @default(uuid()) @db.Uuid
  organizationId String       @db.Uuid
  bankName       String?
  bankCode       String?
  accountNumber  String?
  accountTitle   String?
  IBAN           String?
  branchCode     String?
  branch         String?
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model UserOffice {
  id             String       @id @default(uuid()) @db.Uuid
  userId         String       @db.Uuid
  organizationId String       @db.Uuid
  officeId       String       @db.Uuid
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  office         Office       @relation(fields: [officeId], references: [id], onDelete: Cascade)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId, officeId])
}

model GuardCategory {
  id             String           @id @default(uuid()) @db.Uuid
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  categoryName   String
  organizationId String           @db.Uuid
  assignedGuard  AssignedGuard[]
  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  requestedGuard RequestedGuard[]
}

model Employee {
  id                 String               @id @default(uuid()) @db.Uuid
  userId             String?              @db.Uuid
  organizationId     String               @db.Uuid
  registrationDate   DateTime?
  fullName           String
  fatherName         String?
  dateOfBirth        DateTime?
  cnicNumber         String               @unique
  cnicIssueDate      DateTime
  currentAddress     String?
  permanentAddress   String?
  weight             Float?
  height             Float
  religion           String?
  bloodGroup         String?
  bloodPressure      String?
  heartBeat          String?
  eyeColor           String?
  disability         String?
  eobiNumber         String?
  sessiNumber        String?
  kinName            String?
  kinFatherName      String?
  kinCNIC            String?
  serviceNumber      Int
  cnicExpiryDate     DateTime
  contactNumber      String               @default("N/A")
  kinContactNumber   String?              @default("N/A")
  religionSect       String?              @default("N/A")
  kinRelation        String?              @default("N/A")
  createdAt          DateTime             @default(now())
  isActive           Boolean              @default(true)
  updatedAt          DateTime             @default(now()) @updatedAt
  academic           Academic?
  assignedSupervisor AssignedSupervisor[] @relation("EmployeeAssignedSupervisor")
  supervisorFor      AssignedSupervisor[] @relation("SupervisorForEmployee")
  bankAccount        BankAccount?
  biometric          Biometric?
  drivingLicense     DrivingLicense?
  organization       Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user               User?                @relation(fields: [userId], references: [id], onDelete: Cascade)
  employeeDocuments  EmployeeDocuments?
  employeeExperience EmployeeExperience[]
  references         Reference[]

  @@unique([organizationId, serviceNumber], map: "unique_employee_org_service")
}

model Guard {
  id                         String             @id @default(uuid()) @db.Uuid
  organizationId             String             @db.Uuid
  registrationDate           DateTime?          @default(now())
  fullName                   String
  fatherName                 String?
  dateOfBirth                DateTime?
  cnicNumber                 String             @unique
  cnicIssueDate              DateTime
  currentAddress             String?
  permanentAddress           String?
  weight                     Float?
  height                     Float
  religion                   String?
  bloodGroup                 String?
  bloodPressure              String?
  heartBeat                  String?
  eyeColor                   String?
  disability                 String?
  eobiNumber                 String?
  sessiNumber                String?
  kinName                    String?
  kinFatherName              String?
  kinCNIC                    String?
  serviceNumber              Int
  cnicExpiryDate             DateTime?
  contactNumber              String             @default("N/A")
  currentAreaPoliceContact   String?            @default("N/A")
  currentAreaPoliceStation   String?            @default("N/A")
  kinRelation                String             @default("N/A")
  permanentAreaPoliceContact String?            @default("N/A")
  permanentAreaPoliceStation String?            @default("N/A")
  religionSect               String?            @default("N/A")
  kinContactNumber           String?            @default("N/A")
  officeId                   String?            @db.Uuid
  createdAt                  DateTime           @default(now())
  isActive                   Boolean            @default(true)
  updatedAt                  DateTime           @default(now()) @updatedAt
  userId                     String?            @db.Uuid
  academic                   Academic?
  assignedGuard              AssignedGuard[]
  bankAccount                BankAccount?
  biometric                  Biometric?
  drivingLicense             DrivingLicense?
  office                     Office?            @relation(fields: [officeId], references: [id], onDelete: Cascade)
  organization               Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user                       User?              @relation(fields: [userId], references: [id], onDelete: Cascade)
  guardAllowances            GuardAllowances[]
  guardDeductions            GuardDeductions[]
  guardDocuments             GuardDocuments?
  guardExperience            GuardExperience[]
  guardsAttendance           GuardsAttendance[]
  references                 Reference[]

  // Inventory Relations
  inventoryCards InventoryCard[]
  issuances      IssuanceRegister[]
  returns        ReturnRegister[]

  @@unique([organizationId, serviceNumber], map: "unique_guard_org_service")
}

model Academic {
  id                String    @id @default(uuid()) @db.Uuid
  employeeId        String?   @unique @db.Uuid
  lastEducation     String?
  institute         String?
  hasDrivingLicense Boolean?
  guardId           String?   @unique @db.Uuid
  employee          Employee? @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  guard             Guard?    @relation(fields: [guardId], references: [id], onDelete: Cascade)
}

model DrivingLicense {
  id                       String    @id @default(uuid()) @db.Uuid
  employeeId               String?   @unique @db.Uuid
  drivingLicenseNo         String?
  drivingLicenseIssueDate  DateTime?
  drivingLicenseExpiryDate DateTime?
  licenseIssueCity         String?
  guardId                  String?   @unique @db.Uuid
  employee                 Employee? @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  guard                    Guard?    @relation(fields: [guardId], references: [id], onDelete: Cascade)
}

model GuardExperience {
  id                       String  @id @default(uuid()) @db.Uuid
  guardId                  String? @db.Uuid
  isExServiceMen           Boolean
  exServiceDischargeNumber String?
  armyNumber               String?
  branch                   String?
  serviceYears             Int?
  serviceMonths            Int?
  securityYears            Int?
  place                    String?
  unit                     String?
  recentCivilEmployment    String?
  rankName                 String?
  guard                    Guard?  @relation(fields: [guardId], references: [id], onDelete: Cascade)
}

model EmployeeExperience {
  id                    String    @id @default(uuid()) @db.Uuid
  employeeId            String?   @db.Uuid
  recentCivilEmployment String?
  placeOfDuty           String?
  totalYears            Int?
  employee              Employee? @relation(fields: [employeeId], references: [id], onDelete: Cascade)
}

model Reference {
  id               String    @id @default(uuid()) @db.Uuid
  employeeId       String?   @db.Uuid
  fullName         String
  fatherName       String?
  cnicNumber       String
  contactNumber    String?
  relationship     String?
  currentAddress   String?
  permanentAddress String?
  guardId          String?   @db.Uuid
  cnicBack         String?   @default("N/A")
  cnicFront        String?   @default("N/A")
  employee         Employee? @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  guard            Guard?    @relation(fields: [guardId], references: [id], onDelete: Cascade)
}

model BankAccount {
  id            String    @id @default(uuid()) @db.Uuid
  employeeId    String?   @unique @db.Uuid
  bankName      String?
  bankCode      String?
  accountNumber String?
  IBAN          String?
  branchCode    String?
  branch        String?
  guardId       String?   @unique @db.Uuid
  accountTitle  String?
  employee      Employee? @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  guard         Guard?    @relation(fields: [guardId], references: [id], onDelete: Cascade)
}

model EmployeeDocuments {
  id           String   @id @default(uuid()) @db.Uuid
  employeeId   String   @unique @db.Uuid
  picture      String
  cnicFront    String
  cnicBack     String
  licenseFront String?
  licenseBack  String?
  employee     Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
}

model GuardDocuments {
  id                        String  @id @default(uuid()) @db.Uuid
  guardId                   String? @unique @db.Uuid
  picture                   String
  cnicFront                 String
  cnicBack                  String
  licenseFront              String?
  licenseBack               String?
  policeVerification        String?
  specialBranchVerification String?
  dischargeBook             String?
  NadraVeriSys              String?
  NadraVeriSysRef1          String?
  NadraVeriSysRef2          String?
  healthCertificate         String?
  medicalDocument           String?
  DDCDriving                String?
  educationCertificate      String?
  APSAATrainingCertificate  String?
  misc1                     String?
  misc2                     String?
  originalCNICSubmitted     Boolean @default(false)
  guard                     Guard?  @relation(fields: [guardId], references: [id], onDelete: Cascade)
}

model Biometric {
  id                String    @id @default(uuid()) @db.Uuid
  employeeId        String?   @unique @db.Uuid
  rightThumb        String?
  rightMiddleFinger String?
  rightLittleFinger String?
  leftThumb         String?
  leftMiddleFinger  String?
  leftLittleFinger  String?
  rightForeFinger   String?
  rightRingFinger   String?
  rightFourFinger   String?
  leftFourFinger    String?
  leftRingFinger    String?
  guardId           String?   @unique @db.Uuid
  leftForeFinger    String    @default("Left Fore Finger")
  employee          Employee? @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  guard             Guard?    @relation(fields: [guardId], references: [id], onDelete: Cascade)
}

model Client {
  id                     String               @id @default(uuid()) @db.Uuid
  organizationId         String               @db.Uuid
  recruitmentDate        DateTime
  companyName            String
  industry               String
  websiteLink            String
  address                String
  city                   String
  state                  String
  country                String
  currentAddress         String
  contactNumber          String
  officialEmail          String               @unique
  POCName                String?
  POCDesignation         String?
  POCEmail               String?
  POCContact             String?
  AlternateContactPerson String?
  AlternateContactNumber String?
  createdAt              DateTime             @default(now())
  updatedAt              DateTime             @updatedAt
  isActive               Boolean              @default(true)
  contractFile           String?              @default("N/A")
  contractNumber         Int                  @default(autoincrement())
  userId                 String?              @unique @db.Uuid
  assignedSupervisors    AssignedSupervisor[]
  organization           Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user                   User?                @relation(fields: [userId], references: [id])
  location               Location[]
}

model Shift {
  id               String             @id @default(uuid()) @db.Uuid
  shiftName        String
  guardsAttendance GuardsAttendance[]
  requestedGuards  RequestedGuard[]

  @@map("shifts")
}

model locationType {
  id        String     @id @default(uuid()) @db.Uuid
  type      String
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  isActive  Boolean    @default(true)
  locations Location[]

  @@map("location_types")
}

model Location {
  id                          String                    @id @default(uuid()) @db.Uuid
  organizationId              String                    @db.Uuid
  clientId                    String                    @db.Uuid
  locationName                String
  address                     String
  city                        String
  provinceState               String
  country                     String
  GPScoordinate               String?
  authorizedPersonName        String?
  authorizedPersonNumber      String?
  authorizedPersonDesignation String?
  createdAt                   DateTime                  @default(now())
  createdLocationId           String
  isActive                    Boolean                   @default(true)
  locationTypeId              String?                   @db.Uuid
  updatedAt                   DateTime                  @updatedAt
  officeId                    String?                   @db.Uuid
  assignedGuard               AssignedGuard[]
  assignedSupervisor          AssignedSupervisor[]
  guardDeductions             GuardDeductions[]
  guardsAttendance            GuardsAttendance[]
  payRollDuration             LocationPayRollDuration[]
  taxes                       LocationTaxes[]
  client                      Client                    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  locationType                locationType?             @relation(fields: [locationTypeId], references: [id], onDelete: Cascade)
  office                      Office?                   @relation(fields: [officeId], references: [id], onDelete: Cascade)
  requestedGuards             RequestedGuard[]

  @@map("locations")
}

model RequestedGuard {
  id              String                 @id @default(uuid()) @db.Uuid
  locationId      String                 @db.Uuid
  guardCategoryId String                 @db.Uuid
  quantity        Int
  shiftId         String                 @db.Uuid
  allowance       Float
  chargesPerMonth Float
  overtimePerHour Float
  gazettedHoliday Int?
  assignedGuard   AssignedGuard[]
  guardAllowances GuardAllowances[]
  finances        RequestedGuardFinance?
  guardCategory   GuardCategory          @relation(fields: [guardCategoryId], references: [id], onDelete: Cascade)
  location        Location               @relation(fields: [locationId], references: [id], onDelete: Cascade)
  Shift           Shift                  @relation(fields: [shiftId], references: [id], onDelete: Cascade)

  @@map("requested_guards")
}

model RequestedGuardFinance {
  id               String         @id @default(uuid()) @db.Uuid
  requestedGuardId String         @unique @db.Uuid
  salaryPerMonth   Float
  allowance        Float
  overtimePerHour  Float
  gazettedHoliday  Int?
  requestedGuard   RequestedGuard @relation(fields: [requestedGuardId], references: [id], onDelete: Cascade)

  @@map("requested_guard_finances")
}

model LocationTaxes {
  id         String   @id @default(uuid()) @db.Uuid
  locationId String   @db.Uuid
  taxType    String
  percentage Float?
  amount     Float?
  addInvoice Boolean
  location   Location @relation(fields: [locationId], references: [id], onDelete: Cascade)
}

model AssignedGuard {
  id               String         @id @default(uuid()) @db.Uuid
  guardId          String         @db.Uuid
  locationId       String         @db.Uuid
  requestedGuardId String         @db.Uuid
  deploymentDate   DateTime
  deploymentTill   DateTime?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  guardCategoryId  String         @db.Uuid
  guardCategory    GuardCategory  @relation(fields: [guardCategoryId], references: [id], onDelete: Cascade)
  guard            Guard          @relation(fields: [guardId], references: [id], onDelete: Cascade)
  location         Location       @relation(fields: [locationId], references: [id], onDelete: Cascade)
  requestedGuard   RequestedGuard @relation(fields: [requestedGuardId], references: [id], onDelete: Cascade)
}

model AssignedSupervisor {
  id                   String    @id @default(uuid()) @db.Uuid
  locationId           String    @db.Uuid
  employeeId           String    @db.Uuid
  clientId             String    @db.Uuid
  deploymentDate       DateTime
  deploymentTill       DateTime?
  isActive             Boolean   @default(true)
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  supervisorEmployeeId String    @db.Uuid
  client               Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  employee             Employee  @relation("EmployeeAssignedSupervisor", fields: [employeeId], references: [id], onDelete: Cascade)
  location             Location  @relation(fields: [locationId], references: [id], onDelete: Cascade)
  supervisor           Employee  @relation("SupervisorForEmployee", fields: [supervisorEmployeeId], references: [id], onDelete: Cascade)
}

model GuardsAttendance {
  id         String         @id @default(uuid()) @db.Uuid
  type       AttendanceType
  locationId String         @db.Uuid
  guardId    String         @db.Uuid
  shiftId    String         @db.Uuid
  date       DateTime
  isHoliday  Boolean        @default(false)
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
  overtime   Boolean        @default(false)
  guard      Guard          @relation(fields: [guardId], references: [id], onDelete: Cascade)
  location   Location       @relation(fields: [locationId], references: [id], onDelete: Cascade)
  shift      Shift          @relation(fields: [shiftId], references: [id], onDelete: Cascade)
}

model GuardAllowances {
  id                        String                  @id @default(uuid()) @db.Uuid
  guardId                   String                  @db.Uuid
  allowancePercentage       Float
  holidayCount              Int
  overTimeCount             Int
  createdAt                 DateTime                @default(now())
  updatedAt                 DateTime                @updatedAt
  isActive                  Boolean                 @default(true)
  requestedGuardId          String                  @db.Uuid
  locationPayrollDurationId String                  @db.Uuid
  guard                     Guard                   @relation(fields: [guardId], references: [id], onDelete: Cascade)
  duration                  LocationPayRollDuration @relation(fields: [locationPayrollDurationId], references: [id], onDelete: Cascade)
  requestedGuard            RequestedGuard          @relation(fields: [requestedGuardId], references: [id], onDelete: Cascade)
}

model LocationPayRollDuration {
  id              String            @id @default(uuid()) @db.Uuid
  locationId      String            @db.Uuid
  startDate       DateTime
  endDate         DateTime
  totalDays       Int
  isLocked        Boolean           @default(true)
  nextUnlockTime  DateTime
  isFinalLocked   Boolean           @default(false)
  finalLockedAt   DateTime?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  guardAllowances GuardAllowances[]
  location        Location          @relation(fields: [locationId], references: [id], onDelete: Cascade)
}

model GuardDeductions {
  id            String        @id @default(uuid()) @db.Uuid
  guardId       String        @db.Uuid
  deductionType DeductionType
  amount        Float
  date          DateTime
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  locationId    String        @db.Uuid
  guard         Guard         @relation(fields: [guardId], references: [id], onDelete: Cascade)
  location      Location      @relation(fields: [locationId], references: [id], onDelete: Cascade)
}

// ------------------------------------------
// INVENTORY MANAGEMENT MODULE
// ------------------------------------------

// ------------------------------------------
// 1. SETUP MODULE (Configuration/Dropdowns)
// ------------------------------------------

model Store {
  id             String  @id @default(uuid()) @db.Uuid
  organizationId String  @db.Uuid
  officeId       String  @db.Uuid
  name           String // e.g. "Main Store", "Port Qasim"
  location       String?
  address        String?
  phone          String?
  email          String?
  manager        String?
  capacity       Int?

  organization Organization @relation("OrganizationStores", fields: [organizationId], references: [id], onDelete: Cascade)
  office       Office       @relation("OfficeStores", fields: [officeId], references: [id], onDelete: Cascade)

  inventory          Inventory[]
  purchaseRequests   PurchaseRequest[]
  grns               Grn[]
  stockMovements     StockMovement[]
  stockTransfersFrom StockTransfer[]    @relation("TransferFromStore")
  stockTransfersTo   StockTransfer[]    @relation("TransferToStore")
  inventoryCards     InventoryCard[]    @relation("StoreInventoryCards")
  issuances          IssuanceRegister[] @relation("StoreIssuances")
  returns            ReturnRegister[]   @relation("StoreReturns")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  isActive  Boolean  @default(true)

  @@unique([organizationId, name])
}

model ItemCategory {
  id             String  @id @default(uuid()) @db.Uuid
  organizationId String  @db.Uuid
  name           String // e.g. "New", "Used", "Brought Forward"
  description    String?

  organization Organization @relation("OrganizationItemCategories", fields: [organizationId], references: [id], onDelete: Cascade)
  groups       ItemGroup[]  @relation("ItemCategoryGroups")
  items        Item[]       @relation("ItemCategoryItems")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  isActive  Boolean  @default(true)

  @@unique([organizationId, name])
}

model ItemGroup {
  id             String  @id @default(uuid()) @db.Uuid
  organizationId String  @db.Uuid
  name           String // e.g. "Uniform", "Electronics", "KIT"
  description    String?
  categoryId     String? @db.Uuid

  organization Organization  @relation("OrganizationItemGroups", fields: [organizationId], references: [id], onDelete: Cascade)
  category     ItemCategory? @relation("ItemCategoryGroups", fields: [categoryId], references: [id], onDelete: SetNull)
  items        Item[]        @relation("ItemGroupItems")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  isActive  Boolean  @default(true)

  @@unique([organizationId, name])
}

model Vendor {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @db.Uuid
  name           String // Business name
  contactPerson  String?
  email          String?
  phone          String
  phoneSecondary String?
  address        String?
  city           String?
  country        String?
  paymentTerms   String?
  rating         Decimal? @db.Decimal(3, 2)

  organization   Organization @relation("OrganizationVendors", fields: [organizationId], references: [id], onDelete: Cascade)
  grns           Grn[]
  preferredItems Item[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  isActive  Boolean  @default(true)

  @@unique([organizationId, name])
}

// ------------------------------------------
// 2. ITEM MASTER (Cataloging)
// ------------------------------------------

model Item {
  id             String @id @default(uuid()) @db.Uuid
  organizationId String @db.Uuid

  name        String // Item name
  sku         String // Stock Keeping Unit (unique per org)
  barcode     String? @unique
  description String?

  categoryId String       @db.Uuid
  category   ItemCategory @relation("ItemCategoryItems", fields: [categoryId], references: [id], onDelete: Cascade)

  groupId String    @db.Uuid
  group   ItemGroup @relation("ItemGroupItems", fields: [groupId], references: [id], onDelete: Cascade)

  unitOfMeasurement String // e.g. "Pieces", "Kg", "Liter", "Box", "Pack"
  imagePath         String? // S3 URL

  // Stock thresholds for auto-ordering
  reorderLevel    Int?
  reorderQuantity Int?
  minStockLevel   Int?
  maxStockLevel   Int?

  // Opening balance (if registering existing asset)
  initialPrice        Decimal?  @db.Decimal(10, 2)
  initialPurchaseDate DateTime?

  // Item lifecycle
  expiryDays    Int?
  servicePeriod Int?

  preferredVendorId String? @db.Uuid
  preferredVendor   Vendor? @relation(fields: [preferredVendorId], references: [id], onDelete: SetNull)

  organization       Organization          @relation("OrganizationItems", fields: [organizationId], references: [id], onDelete: Cascade)
  inventory          Inventory[]
  prItems            PurchaseRequestItem[]
  poItems            PurchaseOrderItem[]
  grnItems           GrnItem[]
  movements          StockMovement[]
  inventoryCardItems InventoryCardItem[]
  issuanceItems      IssuanceItem[]
  returnItems        ReturnItem[]
  stockTransferItems StockTransferItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  isActive  Boolean  @default(true)

  @@unique([organizationId, sku])
}

// ------------------------------------------
// 3. LIVE INVENTORY STOCK
// ------------------------------------------

model Inventory {
  id             String @id @default(uuid()) @db.Uuid
  organizationId String @db.Uuid
  storeId        String @db.Uuid
  itemId         String @db.Uuid

  quantityOnHand    Int @default(0) // Current stock
  quantityReserved  Int @default(0) // Reserved for orders
  quantityAvailable Int @default(0) // Available = OnHand - Reserved

  lastCountedDate DateTime?
  minStockLevel   Int?
  maxStockLevel   Int?

  store        Store        @relation(fields: [storeId], references: [id], onDelete: Cascade)
  item         Item         @relation(fields: [itemId], references: [id], onDelete: Cascade)
  organization Organization @relation("OrganizationInventory", fields: [organizationId], references: [id], onDelete: Cascade)

  updatedAt DateTime @updatedAt

  @@unique([storeId, itemId])
}

// ------------------------------------------
// 4. PURCHASE REQUEST (PR)
// ------------------------------------------

model PurchaseRequest {
  id             String @id @default(uuid()) @db.Uuid
  organizationId String @db.Uuid

  prNumber    String  @unique // e.g. "PR-2024-001"
  storeId     String  @db.Uuid
  officeId    String? @db.Uuid // Office from which PR was created
  requestedBy String  @db.Uuid

  requestDate  DateTime  @default(now())
  requiredDate DateTime?

  status      PRStatus @default(DRAFT)
  totalAmount Decimal? @db.Decimal(12, 2)
  notes       String?

  approvedBy   String?   @db.Uuid
  approvalDate DateTime?

  store        Store        @relation(fields: [storeId], references: [id], onDelete: Cascade)
  office       Office?      @relation(fields: [officeId], references: [id], onDelete: SetNull)
  requester    User         @relation("PurchaseRequestRequester", fields: [requestedBy], references: [id], onDelete: Cascade)
  approver     User?        @relation("PurchaseRequestApprover", fields: [approvedBy], references: [id], onDelete: SetNull)
  organization Organization @relation("OrganizationPurchaseRequests", fields: [organizationId], references: [id], onDelete: Cascade)

  items          PurchaseRequestItem[]
  purchaseOrders PurchaseOrder[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PurchaseRequestItem {
  id     String @id @default(uuid()) @db.Uuid
  prId   String @db.Uuid
  itemId String @db.Uuid

  quantity          Int
  unitOfMeasurement String? // e.g. "Small", "Medium", "Large", "Pieces", "Kg", "Liters"
  unitPrice         Decimal? @db.Decimal(10, 2)
  totalPrice        Decimal? @db.Decimal(12, 2)
  notes             String?

  pr   PurchaseRequest @relation(fields: [prId], references: [id], onDelete: Cascade)
  item Item            @relation(fields: [itemId], references: [id], onDelete: Cascade)
}

// ------------------------------------------
// 5. PURCHASE ORDER (PO)
// ------------------------------------------

model PurchaseOrder {
  id             String  @id @default(uuid()) @db.Uuid
  organizationId String  @db.Uuid
  officeId       String? @db.Uuid

  poNumber String @unique // e.g. "PO-2024-001"

  prId            String?          @db.Uuid
  purchaseRequest PurchaseRequest? @relation(fields: [prId], references: [id], onDelete: SetNull)

  orderedBy String @db.Uuid

  orderDate            DateTime  @default(now())
  expectedDeliveryDate DateTime?
  deliveryDate         DateTime?

  status        POStatus      @default(DRAFT)
  paymentStatus PaymentStatus @default(PENDING)

  totalAmount    Decimal? @db.Decimal(12, 2)
  taxAmount      Decimal? @db.Decimal(10, 2)
  shippingCost   Decimal? @db.Decimal(10, 2)
  discountAmount Decimal? @db.Decimal(10, 2)
  netAmount      Decimal? @db.Decimal(12, 2)

  notes String?

  creator      User         @relation(fields: [orderedBy], references: [id], onDelete: Cascade)
  organization Organization @relation("OrganizationPurchaseOrders", fields: [organizationId], references: [id], onDelete: Cascade)
  office       Office?      @relation(fields: [officeId], references: [id], onDelete: SetNull)

  items PurchaseOrderItem[]
  grns  Grn[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PurchaseOrderItem {
  id     String @id @default(uuid()) @db.Uuid
  poId   String @db.Uuid
  itemId String @db.Uuid

  quantityOrdered  Int
  quantityReceived Int     @default(0)
  unitPrice        Decimal @db.Decimal(10, 2)
  totalPrice       Decimal @db.Decimal(12, 2)
  notes            String?

  po       PurchaseOrder @relation(fields: [poId], references: [id], onDelete: Cascade)
  item     Item          @relation(fields: [itemId], references: [id], onDelete: Cascade)
  grnItems GrnItem[]
}

// ------------------------------------------
// 6. GOODS RECEIPT NOTE (GRN)
// ------------------------------------------

model Grn {
  id             String @id @default(uuid()) @db.Uuid
  organizationId String @db.Uuid

  grnNumber String @unique // e.g. "GRN-2024-001"
  poId      String @db.Uuid
  storeId   String @db.Uuid
  vendorId  String @db.Uuid

  grnType GRNType @default(PURCHASE)

  receivedBy   String   @db.Uuid
  receivedDate DateTime @default(now())

  inspectedBy    String?   @db.Uuid
  inspectionDate DateTime?

  status        GRNStatus @default(PENDING)
  totalQuantity Int?
  totalAmount   Decimal?  @db.Decimal(12, 2)
  notes         String?

  purchaseOrder PurchaseOrder @relation(fields: [poId], references: [id], onDelete: Cascade)
  store         Store         @relation(fields: [storeId], references: [id], onDelete: Cascade)
  vendor        Vendor        @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  receiver      User          @relation("GrnReceivedBy", fields: [receivedBy], references: [id], onDelete: Cascade)
  inspector     User?         @relation("GrnInspectedBy", fields: [inspectedBy], references: [id], onDelete: SetNull)
  organization  Organization  @relation("OrganizationGrns", fields: [organizationId], references: [id], onDelete: Cascade)

  items GrnItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model GrnItem {
  id       String  @id @default(uuid()) @db.Uuid
  grnId    String  @db.Uuid
  itemId   String  @db.Uuid
  poItemId String? @db.Uuid

  quantityOrdered  Int?
  quantityReceived Int
  quantityAccepted Int  @default(0)
  quantityRejected Int  @default(0)

  unitPrice  Decimal? @db.Decimal(10, 2)
  totalPrice Decimal? @db.Decimal(12, 2)

  conditionStatus ConditionStatus @default(GOOD)
  batchNumber     String?
  expiryDate      DateTime?
  serialNumber    String?
  notes           String?

  grn    Grn                @relation(fields: [grnId], references: [id], onDelete: Cascade)
  item   Item               @relation(fields: [itemId], references: [id], onDelete: Cascade)
  poItem PurchaseOrderItem? @relation(fields: [poItemId], references: [id], onDelete: SetNull)
}

// ------------------------------------------
// 7. STOCK TRANSFERS (Between Stores)
// ------------------------------------------

model StockTransfer {
  id             String @id @default(uuid()) @db.Uuid
  organizationId String @db.Uuid

  transferNumber String @unique
  fromStoreId    String @db.Uuid
  toStoreId      String @db.Uuid

  transferDate DateTime  @default(now())
  receivedDate DateTime?

  initiatedBy String  @db.Uuid
  receivedBy  String? @db.Uuid

  status TransferStatus @default(DRAFT)
  notes  String?

  fromStore    Store        @relation("TransferFromStore", fields: [fromStoreId], references: [id], onDelete: Cascade)
  toStore      Store        @relation("TransferToStore", fields: [toStoreId], references: [id], onDelete: Cascade)
  initiator    User         @relation("StockTransferInitiator", fields: [initiatedBy], references: [id], onDelete: Cascade)
  receiver     User?        @relation("StockTransferReceiver", fields: [receivedBy], references: [id], onDelete: SetNull)
  organization Organization @relation("OrganizationStockTransfers", fields: [organizationId], references: [id], onDelete: Cascade)

  items StockTransferItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model StockTransferItem {
  id         String @id @default(uuid()) @db.Uuid
  transferId String @db.Uuid
  itemId     String @db.Uuid

  quantityTransferred Int
  quantityReceived    Int     @default(0)
  notes               String?

  transfer StockTransfer @relation(fields: [transferId], references: [id], onDelete: Cascade)
  item     Item          @relation(fields: [itemId], references: [id], onDelete: Cascade)
}

// ------------------------------------------
// 8. INVENTORY CARDS & ISSUANCE
// ------------------------------------------

model InventoryCard {
  id             String @id @default(uuid()) @db.Uuid
  organizationId String @db.Uuid

  cardNumber String  @unique
  guardId    String? @db.Uuid
  storeId    String  @db.Uuid

  issuanceDate DateTime  @default(now())
  returnDate   DateTime?

  status CardStatus @default(ACTIVE)
  notes  String?

  guard        Guard?       @relation(fields: [guardId], references: [id], onDelete: SetNull)
  store        Store        @relation("StoreInventoryCards", fields: [storeId], references: [id], onDelete: Cascade)
  organization Organization @relation("OrganizationInventoryCards", fields: [organizationId], references: [id], onDelete: Cascade)

  items InventoryCardItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model InventoryCardItem {
  id     String @id @default(uuid()) @db.Uuid
  cardId String @db.Uuid
  itemId String @db.Uuid

  quantity          Int
  unitOfMeasurement String?
  isNewSupply       Boolean         @default(true)
  serialNumber      String?
  condition         ConditionStatus @default(NEW)
  notes             String?

  card InventoryCard @relation(fields: [cardId], references: [id], onDelete: Cascade)
  item Item          @relation(fields: [itemId], references: [id], onDelete: Cascade)
}

// ------------------------------------------
// 9. ISSUANCE REGISTER (Issue to Guards/Staff)
// ------------------------------------------

model IssuanceRegister {
  id             String @id @default(uuid()) @db.Uuid
  organizationId String @db.Uuid

  issueNumber String @unique
  guardId     String @db.Uuid
  storeId     String @db.Uuid

  issuanceDate DateTime @default(now())
  issuedBy     String   @db.Uuid

  status IssuanceStatus @default(ISSUED)
  notes  String?

  guard        Guard        @relation(fields: [guardId], references: [id], onDelete: Cascade)
  store        Store        @relation("StoreIssuances", fields: [storeId], references: [id], onDelete: Cascade)
  issuer       User         @relation(fields: [issuedBy], references: [id], onDelete: Cascade)
  organization Organization @relation("OrganizationIssuances", fields: [organizationId], references: [id], onDelete: Cascade)

  items   IssuanceItem[]
  returns ReturnRegister[] @relation("IssuanceReturns")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model IssuanceItem {
  id         String @id @default(uuid()) @db.Uuid
  issuanceId String @db.Uuid
  itemId     String @db.Uuid

  quantity          Int
  unitOfMeasurement String?
  serialNumber      String?
  condition         ConditionStatus @default(NEW)
  notes             String?

  issuance IssuanceRegister @relation(fields: [issuanceId], references: [id], onDelete: Cascade)
  item     Item             @relation(fields: [itemId], references: [id], onDelete: Cascade)
}

// ------------------------------------------
// 10. RETURN REGISTER (Items Returned)
// ------------------------------------------

model ReturnRegister {
  id             String @id @default(uuid()) @db.Uuid
  organizationId String @db.Uuid

  returnNumber String @unique
  issuanceId   String @db.Uuid
  guardId      String @db.Uuid
  storeId      String @db.Uuid

  returnDate DateTime @default(now())
  receivedBy String   @db.Uuid

  totalQuantityReturned Int?
  notes                 String?

  issuance     IssuanceRegister @relation("IssuanceReturns", fields: [issuanceId], references: [id], onDelete: Cascade)
  guard        Guard            @relation(fields: [guardId], references: [id], onDelete: Cascade)
  store        Store            @relation("StoreReturns", fields: [storeId], references: [id], onDelete: Cascade)
  receiver     User             @relation(fields: [receivedBy], references: [id], onDelete: Cascade)
  organization Organization     @relation("OrganizationReturns", fields: [organizationId], references: [id], onDelete: Cascade)

  items ReturnItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ReturnItem {
  id       String @id @default(uuid()) @db.Uuid
  returnId String @db.Uuid
  itemId   String @db.Uuid

  quantityReturned  Int
  unitOfMeasurement String?
  condition         ConditionStatus @default(GOOD)
  notes             String?

  return ReturnRegister @relation(fields: [returnId], references: [id], onDelete: Cascade)
  item   Item           @relation(fields: [itemId], references: [id], onDelete: Cascade)
}

// ------------------------------------------
// 11. STOCK MOVEMENTS (Audit Trail)
// ------------------------------------------

model StockMovement {
  id             String @id @default(uuid()) @db.Uuid
  organizationId String @db.Uuid

  storeId String @db.Uuid
  itemId  String @db.Uuid

  movementType MovementType
  quantity     Int

  referenceType   String? // "GRN", "PR", "TRANSFER", "ISSUANCE", "RETURN"
  referenceId     String?
  referenceNumber String?

  movedBy      String   @db.Uuid
  movementDate DateTime @default(now())
  notes        String?

  store        Store        @relation(fields: [storeId], references: [id], onDelete: Cascade)
  item         Item         @relation(fields: [itemId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [movedBy], references: [id], onDelete: Cascade)
  organization Organization @relation("OrganizationStockMovements", fields: [organizationId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

enum AttendanceType {
  P
  A
  R
  L
}

enum DeductionType {
  sessiPessiFund
  eobiFund
  insurance
  advances
  loanRepayment
  penalty
  miscCharges
}

// ------------------------------------------
// INVENTORY MANAGEMENT ENUMS
// ------------------------------------------

enum PRStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
  CANCELLED
}

enum POStatus {
  DRAFT
  SUBMITTED
  CONFIRMED
  PARTIALLY_RECEIVED
  RECEIVED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  PARTIAL
  PAID
}

enum GRNStatus {
  PENDING
  INSPECTING
  RECEIVED
  PARTIAL
  REJECTED
}

enum GRNType {
  PURCHASE
  TRANSFER
  RETURN
  ADJUSTMENT
}

enum ConditionStatus {
  NEW
  GOOD
  USED
  DAMAGED
  MISSING
  EXPIRED
}

enum MovementType {
  INBOUND
  OUTBOUND
  ADJUSTMENT
  TRANSFER
  RETURN
  ISSUANCE
  CONSUMPTION
}

enum TransferStatus {
  DRAFT
  IN_TRANSIT
  RECEIVED
  CANCELLED
}

enum CardStatus {
  ACTIVE
  RETURNED
  LOST
  DAMAGED
}

enum IssuanceStatus {
  ISSUED
  PARTIAL_RETURN
  FULL_RETURN
  DAMAGED
}

enum AgentStatus {
  ONLINE
  OFFLINE
}

enum ScanStatus {
  PENDING
  COMPLETED
  FAILED
}
